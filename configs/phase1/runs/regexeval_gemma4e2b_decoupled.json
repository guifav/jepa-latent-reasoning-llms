{
  "run_name": "regexeval_gemma4e2b_jepa_reasoner_decoupled_v1",
  "benchmark": "regexeval",
  "model_family": "gemma4",
  "backbone_checkpoint": "google/gemma-4-E2B",
  "adaptation": {
    "backbone": {
      "type": "lora",
      "rank": 16,
      "alpha": 32,
      "dropout": 0.05,
      "target_modules": [
        "q_proj",
        "k_proj",
        "v_proj",
        "o_proj",
        "gate_proj",
        "up_proj",
        "down_proj"
      ]
    },
    "new_modules": "full_train"
  },
  "data": {
    "train_path": "/root/workspace/jepa/data/regexeval/phase1_views/decoupled_reasoner/train_small.jsonl",
    "val_path": "/root/workspace/jepa/data/regexeval/phase1_views/decoupled_reasoner/val_small.jsonl",
    "dev_analysis_path": "/root/workspace/jepa/data/regexeval/phase1_views/decoupled_reasoner/dev_analysis.jsonl",
    "test_frozen_path": "/root/workspace/jepa/data/regexeval/phase1_views/decoupled_reasoner/test_frozen.jsonl"
  },
  "architecture": {
    "latent_rollout": "short",
    "normalization": "rms_plus_l2",
    "talker_size": "small",
    "target_encoder_mode": "shared_backbone_stopgrad"
  },
  "training": {
    "precision": "bf16",
    "gradient_checkpointing": true,
    "per_device_train_batch_size": 2,
    "gradient_accumulation_steps": 16,
    "per_device_eval_batch_size": 4,
    "learning_rate_backbone": 0.0001,
    "learning_rate_new_modules": 0.0002,
    "weight_decay": 0.01,
    "warmup_ratio": 0.05,
    "lr_scheduler": "cosine",
    "stage_1_max_steps": 240,
    "stage_2_max_steps": 240,
    "eval_every_steps": 60,
    "save_every_steps": 60,
    "logging_steps": 20,
    "early_stop_patience_evals": 5,
    "max_condition_tokens": 512,
    "max_talker_target_tokens": 128,
    "stage_3_max_steps": 150,
    "learning_rate_joint": 2e-05,
    "stage_3_unfreeze_backbone": false
  },
  "evaluation": {
    "primary_metric": "semantic_match",
    "secondary_metrics": [
      "exact_match",
      "invalid_regex_rate",
      "prompt_length_bucket_accuracy",
      "regex_length_bucket_accuracy",
      "latent_effective_rank",
      "latent_isotropy_deviation",
      "latent_norm_stability",
      "talker_dependence_ablation"
    ],
    "semantic_evaluator": "/root/workspace/jepa/scripts/eval_regex_semantics.py"
  }
}
