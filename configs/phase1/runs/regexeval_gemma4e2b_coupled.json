{
  "run_name": "regexeval_gemma4e2b_llm_jepa_coupled_v1",
  "benchmark": "regexeval",
  "model_family": "gemma4",
  "backbone_checkpoint": "google/gemma-4-E2B",
  "adaptation": {
    "type": "lora",
    "rank": 16,
    "alpha": 32,
    "dropout": 0.05,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"]
  },
  "data": {
    "train_path": "/root/workspace/jepa/data/regexeval/phase1_views/coupled_prompt_expression/train_small.jsonl",
    "val_path": "/root/workspace/jepa/data/regexeval/phase1_views/coupled_prompt_expression/val_small.jsonl",
    "dev_analysis_path": "/root/workspace/jepa/data/regexeval/phase1_views/coupled_prompt_expression/dev_analysis.jsonl",
    "test_frozen_path": "/root/workspace/jepa/data/regexeval/phase1_views/coupled_prompt_expression/test_frozen.jsonl"
  },
  "jepa": {
    "loss_type": "cosine",
    "lambda": 0.1,
    "predictor_depth": 1,
    "headline_alignment_pair": ["refined_prompt", "expression"],
    "secondary_alignment_pair": ["raw_prompt", "refined_prompt"]
  },
  "training": {
    "precision": "bf16",
    "gradient_checkpointing": true,
    "per_device_train_batch_size": 2,
    "gradient_accumulation_steps": 16,
    "per_device_eval_batch_size": 4,
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "warmup_ratio": 0.05,
    "lr_scheduler": "cosine",
    "max_steps": 480,
    "eval_every_steps": 60,
    "save_every_steps": 60,
    "logging_steps": 20,
    "early_stop_patience_evals": 5,
    "max_packed_input_tokens": 768,
    "max_generation_target_tokens": 128
  },
  "evaluation": {
    "primary_metric": "semantic_match",
    "secondary_metrics": ["exact_match", "invalid_regex_rate", "prompt_length_bucket_accuracy", "regex_length_bucket_accuracy", "latent_effective_rank", "latent_isotropy_deviation", "view_alignment_linearity"],
    "semantic_evaluator": "/root/workspace/jepa/scripts/eval_regex_semantics.py"
  }
}
